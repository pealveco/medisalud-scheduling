# Copy this file to medisalud.env.local for local development.
# medisalud.env.local is ignored by Git and can be customized per machine.
SERVER_PORT=8080
APP_NAME=MediSalud-Scheduling
SPRING_PROFILES_ACTIVE=local

DB_URL=jdbc:postgresql://localhost:5432/medisalud
DB_NAME=medisalud
DB_PORT=5432
DB_USER=medisalud
DB_PASS=medisalud
JPA_DDL_AUTO=update

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080
