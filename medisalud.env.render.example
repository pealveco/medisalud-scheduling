# Plantilla de variables de entorno para Render.
# No crees ni subas al repositorio un medisalud.env.render real con secretos.
#
# Render provee PORT automáticamente. No definas SERVER_PORT salvo que necesites
# sobrescribirlo manualmente. La aplicación lee PORT cuando SERVER_PORT no existe.

# Perfil activo para entorno alojado/runtime.
SPRING_PROFILES_ACTIVE=prod

# Nombre público de la aplicación mostrado por logs de Spring/actuator.
APP_NAME=MediSalud-Scheduling

# Reemplaza RENDER_DB_HOST y el nombre de la base con los valores del dashboard
# de PostgreSQL en Render. Usa el hostname interno cuando la app y la DB estén
# ambas en Render.
DB_URL=jdbc:postgresql://RENDER_DB_HOST:5432/medisalud

# Reemplaza con el usuario de PostgreSQL en Render.
DB_USER=REPLACE_ME

# Reemplaza con la contraseña de PostgreSQL en Render. Este valor es secreto.
DB_PASS=REPLACE_ME

# Normalmente este valor no cambia para PostgreSQL.
DB_DRIVER=org.postgresql.Driver

# Normalmente este valor no cambia para PostgreSQL.
DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# Configuración MVP: permite que Hibernate cree/actualice tablas en una DB nueva
# de Render. En producción con migraciones Flyway/Liquibase, cambia esto a validate.
JPA_DDL_AUTO=update

# Reemplaza con la URL final del Web Service de Render.
CORS_ALLOWED_ORIGINS=https://YOUR_RENDER_APP.onrender.com

# Endpoints de actuator expuestos por la aplicación.
MANAGEMENT_ENDPOINTS=health,prometheus
