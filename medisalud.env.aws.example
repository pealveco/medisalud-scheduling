# Plantilla de variables para el despliegue AWS en EC2 + RDS PostgreSQL.
# No subas al repositorio un medisalud.env.aws real con secretos.

SPRING_PROFILES_ACTIVE=prod
APP_NAME=MediSalud-Scheduling

# Puerto publico expuesto por Docker Compose en EC2.
APP_PORT=80

# Reemplaza RDS_ENDPOINT por el output DatabaseEndpoint de CloudFormation.
DB_URL=jdbc:postgresql://RDS_ENDPOINT:5432/medisalud
DB_USER=medisalud

# Reemplaza por la contrasena configurada en el parametro DbPassword del stack.
DB_PASS=REPLACE_ME
DB_DRIVER=org.postgresql.Driver
DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# MVP: Hibernate crea/actualiza tablas en RDS.
# En produccion real conviene usar migraciones y cambiar a validate.
JPA_DDL_AUTO=update

# Reemplaza con la URL publica de EC2 cuando tengas el output de CloudFormation.
CORS_ALLOWED_ORIGINS=http://EC2_PUBLIC_DNS

MANAGEMENT_ENDPOINTS=health,prometheus
